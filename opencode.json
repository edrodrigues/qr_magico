{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": ""
      }
    },
    "awslabs-aws-documentation-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-documentation-mcp-server@latest"],
      "enabled": true,
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "awslabs-aws-api-mcp-server": {
      "type": "local",
      "command": ["uvx", "--from", "awslabs.aws-api-mcp-server@latest", "awslabs.aws-api-mcp-server.exe"],
      "enabled": true,
      "env": {
        "AWS_REGION": "us-east-1"
      }
    },
    "open-design": {
      "type": "local",
      "command": ["od", "mcp", "--daemon-url", "od://app"],
      "enabled": true,
      "env": {
        "OD_DATA_DIR": "~/.open-design"
      }
    },
    "remotion-documentation": {
      "type": "local",
      "command": ["npx", "@remotion/mcp@latest"],
      "enabled": true
    },
    "resend": {
      "type": "local",
      "command": ["node", "C:\\Users\\lc_admin\\AppData\\Roaming\\npm\\node_modules\\resend-mcp\\dist\\index.js"],
      "enabled": true,
      "env": {
        "RESEND_API_KEY": "re_hKYEv1d1_9Yd9sJ8EhMstR56WfVQk6smR"
      }
    }
  }
}
